# Forge Pool Configuration
# Copy this file to .env and customize

# =============================================================================
# REQUIRED - Set these before starting
# =============================================================================

# Your BCH2 address to receive pool fees and block rewards
POOL_ADDRESS=bitcoincashii:YOUR_ADDRESS_HERE

# =============================================================================
# OPTIONAL - Defaults shown
# =============================================================================

# Pool branding
POOL_NAME=My Forge Pool

# Fee percentages
POOL_FEE=1.0
SOLO_FEE=0.5

# Minimum balance for automatic payout (in BCH2)
MIN_PAYOUT=5

# Ports
STRATUM_PORT=3333
APP_PORT=3080

# =============================================================================
# AUTO-GENERATED - Don't change unless you know what you're doing
# =============================================================================

# These are auto-generated on first run by exports.sh
# NODE_RPC_PASSWORD=
# DB_PASSWORD=

# Data directory (Umbrel sets this automatically)
# APP_DATA_DIR=./data

# Image registry (defaults to GitHub Container Registry)
# IMAGE_REGISTRY=ghcr.io/bitcoincashii
# VERSION=latest
